# Copy this file to .env and fill in your real values
# NEVER commit .env to git — it is already in .gitignore

# Bright Data API key — get from https://brightdata.com/cp/setting/users
# Account settings → API tokens → "Add token" (scope: all zones, no expiration)
BRIGHT_DATA_API_KEY=your_bright_data_api_key_here

# Bright Data dataset IDs — one per logical platform.
# Defaults below are the BD Scrapers-Library IDs picked via the ChatGPT-agent
# setup on 2026-05-21. Override if you author your own Web Scraper IDE clones.
# Each dataset has its own input contract; trigger payloads may need tweaking
# per-dataset (see lib/brightData.ts).
BRIGHT_DATA_DATASET_TIKTOK=gd_l1villgoiiidt09ci
BRIGHT_DATA_DATASET_META=gd_lkaxegm826bjpoo9m5
BRIGHT_DATA_DATASET_INSTAGRAM=gd_l1vikfch901nx3by4
BRIGHT_DATA_DATASET_YOUTUBE=gd_lk56epmy2i5g7lzu0k

# Anthropic API key — get from https://console.anthropic.com/
ANTHROPIC_API_KEY=your_anthropic_key_here

# Postgres connection. Locally, install postgres (`brew install postgresql@16`)
# and `createdb ad_intelligence`, then point both URLs at it.
# In production (Vercel Postgres / Neon), DATABASE_URL is the pooled URL and
# DIRECT_URL is the direct (non-pooled) URL used for migrations — both are
# provided in the Vercel project env when you add the Postgres integration.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ad_intelligence?schema=public"
DIRECT_URL="postgresql://postgres:postgres@localhost:5432/ad_intelligence?schema=public"

# App display name
NEXT_PUBLIC_APP_NAME=Ad Intelligence
